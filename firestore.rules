rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public access to submissions and users for demo/prototyping
    // Note: In production, these should be secured with request.auth
    match /submissions/{submission} {
      allow read, write: if true;
    }
    match /users/{userId} {
      allow read, write: if true;
    }
    match /exams/{examId} {
      allow read, write: if true;
    }
    match /exam_results/{resultId} {
      allow read, write: if true;
    }
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
